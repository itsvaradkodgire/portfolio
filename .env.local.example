ADMIN_PASSWORD=your-secure-password-here
JWT_SECRET=your-random-32-char-jwt-secret-here

# Google AI Studio — hero chat (gemma-3-27b-it, free tier)
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_AI_KEY=your-google-ai-studio-key-here

# Optional: Vercel Blob (production content storage)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token-here

# Optional: Vercel KV (rate limiting)
KV_URL=your-vercel-kv-url-here
KV_REST_API_URL=your-vercel-kv-rest-api-url-here
KV_REST_API_TOKEN=your-vercel-kv-rest-api-token-here
KV_REST_API_READ_ONLY_TOKEN=your-vercel-kv-read-only-token-here
